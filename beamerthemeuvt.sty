%
% This package reproduces the UVT (West University of Timișoara) Power Point
% presentation style defined in the visual identity manual.
%
% Usage:
%   \usetheme[options]{uvt}
%
% References:
%   Colors and Logos: https://dci.uvt.ro/identitate-vizuala
%
% Some other implementations:
%   https://assets-global.website-files.com/641d7b12606bf729cb75f481/6458b9620be9f8af5b003f00_Cercetare%20in%20educatie.pdf

\def\fileversion{v0.4}
\def\filedate{2025/10/26}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeuvt}[\filedate \fileversion UVT Beamer Theme]

% <<< options

\RequirePackage{ifthen}
\RequirePackage{kvoptions}
\SetupKeyvalOptions{
    family=uvt,
    prefix=uvt@
}

% enable Helvetica Now Display
\DeclareBoolOption[false]{helveticanow}
% select language for logos
\DeclareStringOption[english]{language}
% show a debug layout grid
\DeclareBoolOption[false]{showframe}
\DeclareBoolOption[false]{layoutgrid}

\ProcessOptionsBeamer
\DeclareDefaultOption{\PackageWarning{beamerthemeuvt}{Unknown option `\CurrentOption`}}
\ProcessKeyvalOptions*

% >>>

% <<< packages

\RequirePackage{ifpdf}
\RequirePackage{relsize}

% fancy graphics
\RequirePackage{tikz}

% nicer command definitions
\RequirePackage{xparse}
% used in defining blocks
\RequirePackage{adjustbox}
\RequirePackage{colortbl}

\ifuvt@showframe
    \RequirePackage{showframe}
\fi

\ifuvt@layoutgrid
    \RequirePackage[
        grid,
        gridunit=cm,
        gridcolor=gray!70,
        subgridcolor=gray!70,
        texcoord]{eso-pic}
\fi

\usecolortheme{uvt}

% >>>

% <<< commands

\ProvideDocumentCommand \uvtslidelogo { m } {\def\uvt@slidelogo{#1}}
\ProvideDocumentCommand \venue { m } {\def\uvt@venueupper{\MakeUppercase{#1}}}

% >>>

% <<< assets

\ifthenelse{\equal{\uvt@language}{english}}{
    \ProvideDocumentCommand \PageWord {} {Page}
    \uvtslidelogo{\includegraphics[width=0.55\paperheight]{assets/uvt-background-logo-black-en}}
}{
\ifthenelse{\equal{\uvt@language}{romanian}}{
    \ProvideDocumentCommand \PageWord {} {Pagina}
    \uvtslidelogo{\includegraphics[width=0.55\paperheight]{assets/uvt-background-logo-black-ro}}
}{
    \PackageError{beamerthemeuvt}{Unknown language `\uvt@language`}{}
}}

% >>>

% <<< fonts

\ifpdftex
    \RequirePackage[utf8]{inputenc}
    \RequirePackage[T1]{fontenc}
\else
    \RequirePackage{fontspec}
\fi

\ifuvt@helveticanow
    \ifpdftex
        \PackageWarning{uvt-letterhead}{HelveticaNowDisplay font is not available on pdfLaTeX. Remove the 'helveticanow' option to silence this warning or switch to LuaLaTeX / XeLaTex.}
        \RequirePackage[scale=0.9]{tgheros}
    \else
        \IfFontExistsTF{HelveticaNowDisplay}{
            \setsansfont[Ligatures=TeX]{HelveticaNowDisplay}
        }{
            \PackageWarning{uvt-letterhead}{HelveticaNowDisplay font is not available on your system. Remove the 'helveticanow' option to silence this warning.}
            \setsansfont[Scale=0.9]{TeX Gyre Heros}}
    \fi
\else
    \ifpdftex
        \RequirePackage[scale=0.9]{tgheros}
    \else
        \setsansfont[Scale=0.9]{TeX Gyre Heros}
    \fi
\fi
\renewcommand{\familydefault}{\sfdefault}

\setbeamerfont{title}{size*={20.74}{24.88}, series=\bfseries}
\setbeamerfont*{subtitle}{size*={12}{14.4}, series=\mdseries}
\setbeamerfont{author}{size*={10.95}{13.14}, series=\bfseries}
\setbeamerfont{date}{size*={10}{12}, series=\mdseries}

\setbeamerfont{frametitle}{size*={14.4}{17.28}, series=\bfseries}
\setbeamerfont{framesubtitle}{size*={10.95}{13.14}, series=\mdseries}
\setbeamerfont{section title}{size=\LARGE, series=\bfseries}

\setbeamerfont{venue in header}{size*={8}{9.6}, series=\bfseries}
\setbeamerfont{text in footer}{size*={8}{9.6}, series=\bfseries}

\setbeamerfont{footnote}{size=\tiny}

\setbeamerfont{alerted text} {series=\bfseries}
\setbeamerfont{block title}{size=\relsize{+1}, series=\bfseries}
\setbeamerfont{block title alerted}{size=\relsize{+1}, series=\bfseries}

\setbeamerfont{enumerate item}{size={}, series=\bfseries}
\setbeamerfont{description item}{size={}, series=\bfseries}

\setbeamerfont{itemize/enumerate body}{size={}}
\setbeamerfont{itemize/enumerate subbody}{size={}}
\setbeamerfont{itemize/enumerate subsubbody}{size={}}

% >>>

% <<< outer: header / footer

\defbeamertemplate*{frametitle}{uvtframe}{
    \nointerlineskip%
    \begin{tikzpicture}[remember picture, overlay]
    % top-left logo
    \fill[UVTBeamerDarkBlue]
        ([xshift=0.5cm, yshift=-1.5cm]current page.north west)
        rectangle
        ([xshift=2cm, yshift=0cm]current page.north west);
    \node at ([xshift=1.25cm, yshift=-0.75cm]current page.north west)
        {\includegraphics[width=1.5cm]{assets/logo-uvt-white}};
    \end{tikzpicture}%
    \hbox to \paperwidth{%
        \hskip 1.75cm\relax
        \vbox to \dimexpr1.0cm + \dp\strutbox\relax{%
            \vss
            \ifx\insertframesubtitle\empty
                {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\strut\par}
                \vskip -4.25mm
            \else
                {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle} \\
                {\usebeamerfont{framesubtitle}\usebeamercolor[fg]{framesubtitle}\insertframesubtitle\strut\par}
                \vskip -4mm
            \fi
        }
    }
    \vskip\dimexpr0.15cm + \dp\strutbox\relax
}

\defbeamertemplate{footline}{uvtframe}{
    \begin{tikzpicture}[remember picture, overlay]
    \fill[UVTBeamerDarkBlue]
        (current page.south west)
        rectangle
        ([yshift=0.4cm]current page.south east);
    \fill[UVTBeamerDarkGray]
        ([yshift=0.4cm]current page.south west)
        rectangle
        ([yshift=0.45cm]current page.south east);
    \end{tikzpicture}%
    \begin{beamercolorbox}[wd=0.8\paperwidth, ht=0.45cm, dp=0pt, left]{text in footer}%
        \vbox to 0.3cm{\vfil
            \hspace{\beamer@leftmargin}%
            \usebeamerfont{text in footer}%
            \insertshortauthor ~~~---~~ \uvt@venueupper%
        \vfil}%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.2\paperwidth, ht=0.45cm, dp=0pt, right,
                           rightskip=\beamer@leftmargin]{text in footer}%
        \vbox to 0.3cm{\vfil
            \usebeamerfont{text in footer}%
            \PageWord{} \insertframenumber~/~\inserttotalframenumber%
        \vfil}%
    \end{beamercolorbox}%
}
\setbeamertemplate{footline}[uvtframe]

% >>>

% <<< inner: environments

% <<< templates

\setbeamertemplate{background}[uvtslide]

\NewDocumentCommand \titleframe {} {
    \setbeamertemplate{title page}[uvttitlepage]
    \setbeamertemplate{background}[uvttitlepage]
    \frame[plain,noframenumbering]{\titlepage}
    \setbeamertemplate{background}[uvtslide]
}

\NewDocumentCommand \sectionframe {} {
    \setbeamertemplate{section page}[uvtsectionpage]
    \setbeamertemplate{background}[uvttitlepage]
    \frame[plain,noframenumbering]{\sectionpage}
    \setbeamertemplate{background}[uvtslide]
}
\AtBeginSection{
    \sectionframe
}

% >>>

% <<< title page

\defbeamertemplate{title page}{uvttitlepage}
{
    \begin{tikzpicture}[remember picture, overlay]
    % top right
    \node[anchor=north east, opacity=0.5, inner xsep=0pt]
        at ([xshift=-0.5cm, yshift=-0.1cm]current page.north east)
        {\usebeamerfont{venue in header}\textcolor{UVTWhite}{{\textbf{\uvt@venueupper}}}};

    % bottom left
    \node[anchor=south west, opacity=0.5, inner xsep=0pt]
        at ([xshift=0.5cm, yshift=0.0cm]current page.south west)
        {\textcolor{UVTWhite}{\href{https://www.uvt.ro}{\textbf{www.uvt.ro}}}};
    \end{tikzpicture}

    \vfill
    \begin{center}
        % title format
        \usebeamerfont{title}\usebeamercolor[fg]{title}
        \inserttitle\par
        % subtitle
        \usebeamerfont{subtitle}\insertsubtitle\par%
        \bigskip
        % author
        \usebeamerfont{author}\insertauthor\par%
        \medskip
        % date
        \usebeamerfont{date}\insertdate%
    \end{center}
    \vfill
}

\defbeamertemplate{section page}{uvtsectionpage}
{
    \vfill
    \begin{center}
        \usebeamerfont{section title}\usebeamercolor[fg]{section title}
        \insertsectionhead\par
    \end{center}
    \vfill
}

% >>>

% <<< background

% NOTE: this is here as a performance hack: it embeds the logo in the PDF once and we
% can then just reuse it to create the pattern lower down. It should be a lot faster.
\pgfdeclareimage[width=1.5cm]{uvtlogo}{assets/logo-uvt-tile.pdf}

\defbeamertemplate{background}{uvttitlepage}
{
    \begin{tikzpicture}[remember picture, overlay]
    % background
    \fill[UVTBeamerDarkBlue] (current page.south west) rectangle (current page.north east);

    % pattern
    \begin{scope}[opacity=0.03]
    \pgfmathsetmacro{\pw}{\paperwidth / 1cm}
    \pgfmathsetmacro{\ph}{\paperheight / 1cm}

    \foreach \y in {0.5, -1.0, ..., -\ph} {
        \pgfmathsetmacro{\yeven}{\y}
        \foreach \x in {0, 1.5, ..., \pw} {
            \node[inner sep=0, anchor=north west]
                at ([xshift=\x cm, yshift=\yeven cm]current page.north west)
                {\pgfuseimage{uvtlogo}};
        }
        \pgfmathsetmacro{\yodd}{\y - 0.75}
        \foreach \x in {-0.85, 0.65, 2.15, ..., \pw} {
            \node[inner sep=0, anchor=north west]
                at ([xshift=\x cm, yshift=\yodd cm]current page.north west)
                {\pgfuseimage{uvtlogo}};
        }
    }
    \end{scope}

    % top-left logo
    \fill[UVTWhite]
        ([xshift=0.5cm, yshift=-1.5cm]current page.north west)
        rectangle
        ([xshift=2cm, yshift=0cm]current page.north west);
    \node at ([xshift=1.25cm, yshift=-0.75cm]current page.north west)
        {\includegraphics[width=1.5cm]{assets/logo-uvt-blue}};
    \end{tikzpicture}%
}

\defbeamertemplate{background}{uvtslide}{
    \begin{tikzpicture}[remember picture, overlay]
        \node [opacity=0.0175] at (current page.center) {\uvt@slidelogo};
    \end{tikzpicture}
}

% >>>

% <<< itemize

\setbeamertemplate{itemize item}{
    \tikz[baseline=-0.65ex]{
        % circle
        \node[
        circle,
        minimum size=1ex,
        inner sep=0pt,
        draw=UVTDarkBlue
        ] (c) {};
    }
}

\setbeamertemplate{itemize subitem}{\color{UVTDarkBlue}\small $\bullet$}
\setbeamertemplate{itemize subsubitem}{\color{UVTSkyBlue}\small $\bullet$}

% >>>

% <<< blocks

\setbeamertemplate{block begin}{
    \vspace{\fill}
    \begin{adjustbox}{max width=0.98\textwidth}
        \begin{tabular}{!{\color{UVTDarkBlue}{\vrule width 4pt}}>{\columncolor[gray]{0.97}}m{\textwidth}}
    	    \begin{beamercolorbox}{block title}
                \usebeamerfont*{block title}
                \vbox{}\vskip 0.05ex
                \insertblocktitle
                \vbox{}\vskip 0.2ex
            \end{beamercolorbox}
            \usebeamerfont*{block text}
}
\setbeamertemplate{block end}{\end{tabular}\end{adjustbox}}

\setbeamertemplate{block alerted begin}{
    \vspace{\fill}
    \begin{adjustbox}{max width=0.98\textwidth}
        \begin{tabular}{!{\color{UVTBeamerYellow}{\vrule width 4pt}}>{\columncolor[gray]{0.97}}m{\textwidth}}
    	    \begin{beamercolorbox}{alerted text}
                \usebeamerfont*{block title}
                \vbox{}\vskip 0.05ex
                \insertblocktitle
                \vbox{}\vskip 0.2ex
            \end{beamercolorbox}
            \usebeamerfont*{block text}
}
\setbeamertemplate{block alerted end}{\end{tabular}\end{adjustbox}}

\setbeamertemplate{block example begin}{
    \vspace{\fill}
    \begin{adjustbox}{max width=0.98\textwidth}
        \begin{tabular}{!{\color{UVTLightBlue}{\vrule width 4pt}}>{\columncolor[gray]{0.97}}m{\textwidth}}
    	    \begin{beamercolorbox}{example text}
                \usebeamerfont*{block title}
                \vbox{}\vskip 0.05ex
                \insertblocktitle
                \vbox{}\vskip 0.2ex
            \end{beamercolorbox}
            \usebeamerfont*{block text}
}
\setbeamertemplate{block example end}{\end{tabular}\end{adjustbox}}

% >>>

% <<< figures

% disable "Figure:" in the captions
\setbeamertemplate{caption}{\insertcaption}
\setbeamertemplate{caption label separator}{}

% >>>

\setbeamersize{
    text margin left=0.5cm,
    text margin right=0.5cm,
    description width=0.075\paperwidth,
    }
\setlength{\labelsep}{\dimexpr\labelsep - 0.2em\relax}

